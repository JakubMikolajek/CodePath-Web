{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CORS_ALLOWED_ORIGINS",
    "DATABASE_URL",
    "GIT_SSH_COMMAND",
    "JWT_EXPIRES_IN",
    "JWT_EXPIRES_IN_SECONDS",
    "JWT_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "PORT",
    "ORCHESTRATOR_URL",
    "QDRANT_HOST",
    "QDRANT_PORT",
    "RABBIT_ALLOW_DESTRUCTIVE_MIGRATION",
    "RABBIT_RETRY_DELAY_MS",
    "RABBIT_URL"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
