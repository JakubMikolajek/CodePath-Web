{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "AUTH_KEYCLOAK_ID",
    "AUTH_KEYCLOAK_ISSUER",
    "AUTH_KEYCLOAK_SECRET",
    "AUTH_SECRET",
    "AUTH_URL",
    "CORS_ALLOWED_ORIGINS",
    "DATABASE_URL",
    "GIT_SSH_COMMAND",
    "INTERNAL_API_BASE_URL",
    "INTERNAL_API_URL",
    "KEYCLOAK_ALLOWED_AUDIENCES",
    "KEYCLOAK_CLIENT_ID",
    "KEYCLOAK_CLIENT_SECRET",
    "KEYCLOAK_ISSUER",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "PORT",
    "ORCHESTRATOR_URL",
    "QDRANT_HOST",
    "QDRANT_PORT",
    "RABBIT_ALLOW_DESTRUCTIVE_MIGRATION",
    "RABBIT_RETRY_DELAY_MS",
    "RABBIT_URL"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
